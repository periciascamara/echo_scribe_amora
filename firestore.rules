rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields: uid, email, displayName, photoURL, role, createdAt
    //
    // Collection: patients
    // Fields: id, name, age, gender, lastVisit, status, ownerUid
    //
    // Collection: scripts
    // Fields: id, name, category, tags, isFavorite, status, instructions, checklist, ownerUid
    //
    // Collection: templates
    // Fields: id, name, category, status, sections, instructions, latexTemplate, ownerUid
    //
    // Collection: history
    // Fields: id, patientId, patientName, date, type, summary, ownerUid
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(ownerUid) {
      return isAuthenticated() && request.auth.uid == ownerUid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "guilherme.ribeiro.camara@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(uid) && 
                    request.resource.data.role == resource.data.role && 
                    isValidUser(request.resource.data);
    }

    match /patients/{patientId} {
      allow read: if isOwner(resource.data.ownerUid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOwner(resource.data.ownerUid) && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if isOwner(resource.data.ownerUid) || isAdmin();
    }

    match /scripts/{scriptId} {
      allow read: if isOwner(resource.data.ownerUid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOwner(resource.data.ownerUid) && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if isOwner(resource.data.ownerUid) || isAdmin();
    }

    match /templates/{templateId} {
      allow read: if isOwner(resource.data.ownerUid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOwner(resource.data.ownerUid) && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if isOwner(resource.data.ownerUid) || isAdmin();
    }

    match /history/{historyId} {
      allow read: if isOwner(resource.data.ownerUid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOwner(resource.data.ownerUid) && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if isOwner(resource.data.ownerUid) || isAdmin();
    }
  }
}
